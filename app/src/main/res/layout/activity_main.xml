<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">


    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Z-КАЗИНО"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvSlogan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ЕДИНСТВЕННОЕ КАЗИНО"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="В 500+ игр 70+ провайдеров. Наше казино заполнено игровыми автоматами, настольными играми и крупными выигрышами!"
        android:textSize="16sp"
        android:textColor="#CCCCCC"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="20dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvSlogan"/>


    <TextView
        android:id="@+id/tvJackpot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="JACKPOT"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvDescription"/>

    <TextView
        android:id="@+id/tvJackpotAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$ 1 000 000"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="#FF4500"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvJackpot"/>


    <LinearLayout
        android:id="@+id/layoutSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#33000000"
        android:padding="20dp"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvJackpotAmount"
        android:elevation="4dp">


        <TextView
            android:id="@+id/tvReel1"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🍒"
            android:textSize="48sp"
            android:background="@drawable/bg_reel"
            android:layout_margin="4dp"/>


        <TextView
            android:id="@+id/tvReel2"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🍋"
            android:textSize="48sp"
            android:background="@drawable/bg_reel"
            android:layout_margin="4dp"/>


        <TextView
            android:id="@+id/tvReel3"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🍊"
            android:textSize="48sp"
            android:background="@drawable/bg_reel"
            android:layout_margin="4dp"/>

    </LinearLayout>

    <!-- Кнопка SPIN -->
    <Button
        android:id="@+id/btnSpin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SPIN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutSlot"/>

    <!-- Результат -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/btnSpin"/>

</androidx.constraintlayout.widget.ConstraintLayout>