<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Основной контент -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Верхняя панель: Бургер + Баланс -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Бургер меню -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:src="@drawable/ic_menu"
                android:contentDescription="Меню"
                android:padding="12dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Баланс -->
            <TextView
                android:id="@+id/tvBalanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Баланс:"
                android:textSize="16sp"
                android:textColor="@color/text_black"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 1000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Заголовок -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Z-КАЗИНО"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:fontFamily="monospace"
            app:layout_constraintTop_toBottomOf="@id/topBar"/>

        <TextView
            android:id="@+id/tvSlogan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ЕДИНСТВЕННОЕ КАЗИНО"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

        <!-- Джекпот -->
        <TextView
            android:id="@+id/tvJackpot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JACKPOT"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvSlogan"/>

        <TextView
            android:id="@+id/tvJackpotAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$ 1 000 000"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FF4500"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvJackpot"/>

        <!-- Слоты -->
        <LinearLayout
            android:id="@+id/layoutSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#33000000"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvJackpotAmount">

            <TextView
                android:id="@+id/tvReel1"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🍒"
                android:textSize="40sp"
                android:background="@drawable/bg_reel"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/tvReel2"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🍋"
                android:textSize="40sp"
                android:background="@drawable/bg_reel"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/tvReel3"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🍊"
                android:textSize="40sp"
                android:background="@drawable/bg_reel"
                android:layout_margin="4dp"/>
        </LinearLayout>

        <!-- Кнопка SPIN -->
        <Button
            android:id="@+id/btnSpin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SPIN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9C27B0"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutSlot"/>

        <!-- Результат -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnSpin"/>

        <!-- Email пользователя -->
        <TextView
            android:id="@+id/tvUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvResult"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Боковое меню (Navigation Drawer) -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Z-казино"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/purple_primary"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Профиль"
            android:textSize="18sp"
            android:textColor="@color/text_black"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/menuHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="История игр"
            android:textSize="18sp"
            android:textColor="@color/text_black"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/menuSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки"
            android:textSize="18sp"
            android:textColor="@color/text_black"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚪 Выйти"
            android:textSize="18sp"
            android:textColor="#D32F2F"
            android:padding="12dp"/>

    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>