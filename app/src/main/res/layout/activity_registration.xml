<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <TextView
        android:id="@+id/tvAppTitleReg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Z-казино"
        android:textSize="32sp"
        android:textColor="@color/text_black"
        android:fontFamily="monospace"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitleReg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Карточка регистрации -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/reg_title"
                        android:textAlignment="center"
                        android:textSize="22sp"
                        android:fontFamily="serif-monospace"
                        android:layout_marginBottom="20dp"/>

                    <!-- Фамилия и Имя -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <EditText
                            android:id="@+id/etSurname"
                            android:layout_width="0dp"
                            android:layout_height="45dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:hint="@string/hint_surname"
                            android:paddingStart="12dp"
                            android:layout_marginEnd="8dp"/>

                        <EditText
                            android:id="@+id/etName"
                            android:layout_width="0dp"
                            android:layout_height="45dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:hint="@string/hint_name"
                            android:paddingStart="12dp"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etPatronymic"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/hint_patronymic"
                        android:paddingStart="12dp"
                        android:layout_marginTop="12dp"/>

                    <!-- Дата и Пол -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginTop="12dp">

                        <EditText
                            android:id="@+id/etDob"
                            android:layout_width="0dp"
                            android:layout_height="45dp"
                            android:layout_weight="1.5"
                            android:background="@drawable/bg_input"
                            android:hint="@string/hint_dob"
                            android:paddingStart="12dp"
                            android:focusable="false"
                            android:clickable="true"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/swGender"
                            android:layout_width="0dp"
                            android:layout_height="45dp"
                            android:layout_weight="0.5"
                            android:text="M"
                            android:textColor="@color/purple_primary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etEmailPhone"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/hint_email_phone"
                        android:paddingStart="12dp"
                        android:layout_marginTop="12dp"/>

                    <!-- БЛОК ПОДСКАЗКИ ПАРОЛЯ (ИСПРАВЛЕННЫЙ) -->
                    <!-- Заменили CardView на LinearLayout с фоном bg_error_box -->
                    <LinearLayout
                        android:id="@+id/cardPasswordHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:background="@drawable/bg_error_box"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pass_hint_title"
                            android:textColor="@color/error_red"
                            android:textAlignment="center"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pass_req_1"
                            android:textColor="@color/text_black"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pass_req_2"
                            android:textColor="@color/text_black"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pass_req_3"
                            android:textColor="@color/text_black"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pass_req_4"
                            android:textColor="@color/text_black"
                            android:textSize="11sp"
                            android:fontStyle="italic"/>

                        <TextView
                            android:id="@+id/tvCloseHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="X"
                            android:textColor="@color/error_red"
                            android:textSize="20sp"
                            android:layout_gravity="end"/>
                    </LinearLayout>
                    <!-- КОНЕЦ БЛОКА ПОДСКАЗКИ -->

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/hint_password"
                        android:paddingStart="12dp"
                        android:inputType="textPassword"
                        android:layout_marginTop="12dp"/>

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_input"
                        android:hint="@string/hint_confirm_pass"
                        android:paddingStart="12dp"
                        android:inputType="textPassword"
                        android:layout_marginTop="12dp"/>

                    <!-- Чекбоксы -->
                    <CheckBox
                        android:id="@+id/cbAgreement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/check_agreement"
                        android:textSize="11sp"
                        android:layout_marginTop="12dp"/>

                    <CheckBox
                        android:id="@+id/cbPersonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/check_personal"
                        android:textSize="11sp"/>

                    <CheckBox
                        android:id="@+id/cbResponsibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/check_responsibility"
                        android:textSize="11sp"/>

                    <Button
                        android:id="@+id/btnRegister"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="@string/btn_register"
                        android:textColor="@color/text_black"
                        android:backgroundTint="#E1BEE7"
                        android:textAllCaps="false"
                        android:fontFamily="serif-monospace"
                        android:textSize="18sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvHaveAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/have_account"
                        android:textAlignment="center"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>